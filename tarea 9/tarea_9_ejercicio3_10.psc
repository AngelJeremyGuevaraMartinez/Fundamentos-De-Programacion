Algoritmo tarea_9_ejercicio3_10
	
	Definir fahrenheit, celsius, celsiusf Como Real
	
	fahrenheit <- 40
	
	celsius <- 5.0 / 9 * fahrenheit - 32
	celsiusf <- (5.0 / 9) * (fahrenheit - 32)
	
	Escribir "5.0 / 9 * fahrenheit - 32 = ", celsius
	Escribir "(5.0 / 9) * (fahrenheit - 32) = ", celsiusf
	
FinAlgoritmo
