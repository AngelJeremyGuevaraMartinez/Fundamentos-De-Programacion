Algoritmo tarea_9_ejercicio4_10
	
	Definir altura1, base1 Como Entero
	Definir area3 Como Real
	
	altura1 <- ConvertirANumero("50")
	base1 <- ConvertirANumero("20")
	
	area3 <- (base1 * altura1) / 2
	
	Escribir "El area de un triangulo de altura: ", altura1, " Base ", base1, " = ", area3
	
FinAlgoritmo
